# Example environment configuration.
# Replace these placeholder values in your local untracked .env.local or deployment secrets.

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
HF_FINEGRAINED_TOKEN=YOUR_HF_FINEGRAINED_TOKEN
HF_READ_TOKEN=YOUR_HF_READ_TOKEN
HF_WRITE_TOKEN=YOUR_HF_WRITE_TOKEN
GOOGLE_API_KEY_3=YOUR_GOOGLE_API_KEY
HF_TOKEN=YOUR_HF_TOKEN
# ── FIRE Recommendations Rate Limits ──────────────────────────────────────────
# Max times the live AI pipeline runs per user per calendar day.
# Increase these numbers to allow more calls - no code change needed.
FIRE_DAILY_ANALYSIS_LIMIT=10
FIRE_DAILY_PREFETCH_LIMIT=10